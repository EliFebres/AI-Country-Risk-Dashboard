# ──────────────────────────────────────────────────────────────────────────────
# How to use
# 1) Copy this file to `.env` (e.g., backend/.env).
# 2) Fill in the blanks.
# ──────────────────────────────────────────────────────────────────────────────

# === PostgreSQL (Neon) ========================================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
DATABASE_URL=''

# === OpenAI ===================================================================
# Key usually starts with "sk-". Do NOT expose via NEXT_PUBLIC_*.
OPENAI_API_KEY=''

# === Crawlbase ================================================================
# Server-side token for Crawlbase REST API (advanced scraper).
CRAWLBASE_TOKEN=''

# Optional: client-side token for the Crawlbase JS snippet
CRAWLBASE_JS_TOKEN=''

# === FMP (Financial Modeling Prep) ============================================
# API key for the economic-calendar feed (Econ Calendar pane) AND the live
# Prices feed (prices_daemon.py: batch-quote, historical-price-eod, and
# treasury-rates endpoints). Plan must include those endpoints. The Prices
# daemon reuses this key and DATABASE_URL above — no other secret is needed.
FMP_API_KEY=''
